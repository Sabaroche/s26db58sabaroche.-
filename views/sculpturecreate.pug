extends layout

block content
  h1= title
 
  form(id='SculptureForm', action="/resource/sculptures", method="POST")
    div.form-group
        label.sculptureAttr(for='sculpture_material') Sculpture material
        input#sculpture_material(type='text', name='material')
    div.form-group
        label.sculptureAttr(for='sculpture_style') Sculpture style
        input#sculpture_style(type='text', name='style')
    div.form-group
        label.sculptureAttr(for='sculpture_year') Sculpture year
        input#sculpture_year(type='number', name='year')
    input(type="submit")

 script.
  document.forms['SculptureForm'].addEventListener('submit', (event) => {
    event.preventDefault();
    fetch(event.target.action, {
      method: 'POST',
      body: new URLSearchParams(new FormData(event.target))
    }).then((resp) => {
      if (!resp.ok) {
        return resp.text().then(text => { throw new Error(text) });
      }
      return resp.json();
    }).then((body) => {
      alert("Save succeeded")
    }).catch((error) => {
      alert("Save failed: " + error)
    });
  });
